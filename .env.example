# ── Required ─────────────────────────────────────────────────────────────────
# Core LLM inference — every node calls the LLM through this key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Hugging Face — required for tooluniverse (model/dataset discovery on HF Hub)
HF_TOKEN=hf_your-token-here

# GitHub — required for github-mining (code/repo search via GitHub API)
GITHUB_TOKEN=ghp_your-token-here

# ── Optional: extra model providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_API_KEY=

# ── Inference config ──────────────────────────────────────────────────────────
# Base URL for the OpenAI-compatible API endpoint
INFERENCE_BASE_URL=https://openrouter.ai/api/v1

# Model identifier (as accepted by the endpoint above)
MODEL_NAME=z-ai/glm-5

# Pricing (dollars per 1 million tokens) — set manually from provider pricing page
INPUT_TOKEN_COST_PER_MILLION=0.95
OUTPUT_TOKEN_COST_PER_MILLION=2.55

# ── Agent window sizes ────────────────────────────────────────────────────────
# QueueManager: how many recent history entries to show the LLM
LOOKBACK=2

# QueueManager: how many upcoming pending todos to inspect/adjust
LOOKAHEAD=3
