{
  "mcpServers": {
    "arxiv": {
      "description": "Search and fetch academic papers from arXiv",
      "transport": "stdio",
      "command": "arxiv-mcp-server",
      "args": [],
      "tags": ["academic-search"],
      "pip_package": "arxiv-mcp-server"
    },
    "context7": {
      "description": "Fast documentation lookup for libraries and frameworks",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "env_key": "CONTEXT7_API_KEY",
      "env_optional": true,
      "tags": ["documentation"]
    },
    "deepwiki": {
      "description": "Search and read GitHub repository documentation",
      "transport": "streamable_http",
      "url": "https://mcp.deepwiki.com/mcp",
      "tags": ["documentation"]
    },
    "docs-langchain": {
      "description": "Documentation for building agents with LangChain",
      "transport": "streamable_http",
      "url": "https://docs.langchain.com/mcp",
      "tags": ["documentation"]
    },
    "exa": {
      "description": "Neural web search and content retrieval via Exa",
      "transport": "http",
      "url": "https://mcp.exa.ai/mcp",
      "tags": ["web-search"]
    },
    "perplexity": {
      "description": "AI-powered web search via Perplexity",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      },
      "env_key": "PERPLEXITY_API_KEY",
      "tags": ["web-search"]
    },
    "sequential-thinking": {
      "description": "Chain-of-thought reasoning with sequential thinking steps",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "tags": ["reasoning"]
    },
    "ssh": {
      "description": "Execute commands and transfer files on remote servers via SSH",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@aiondadotcom/mcp-ssh"],
      "tags": ["remote-execution"]
    }
  }
}
